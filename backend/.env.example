PORT=8080

# PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/healconnect"

# JWT Secrets
JWT_ACCESS_SECRET=your_access_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars

# SendGrid
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=HealConnect

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Twilio Verify (for SMS OTP — no phone number needed)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxx

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_STORAGE_CONTAINER=profile-photos

# Redis
REDIS_URL="redis://localhost:6379"

# Frontend URL (for email links & CORS)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
